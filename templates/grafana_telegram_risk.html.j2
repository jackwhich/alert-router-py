{# timeout/volume 仍按 alertname；manual 优先按 Grafana receiver（通知策略名），避免 alertname 仅为中文展示名时无法匹配 #}
{% set an = (labels.get("alertname") or "") | string %}
{% set rw = (labels.get("risk-withdraw-alarm") or "") | string %}
{% set rec = (receiver or "") | string %}
{% set kind = (
  "timeout" if (an == "ris-mk-api-timeout-time-result-overtime" or "ris-mk-api-timeout-time-result-overtime" in an)
  else "volume" if (an == "risk-reject-review-volume-overlimit" or "risk-reject-review-volume-overlimit" in an)
  else "manual" if (
    rec == "Withdrawal_Monitoring_Review"
    or an == "risk-manual-review-alarm" or "risk-manual-review-alarm" in an
    or rw == "risk-manual-review-alarm" or "risk-manual-review-alarm" in rw
  )
  else ""
) %}

